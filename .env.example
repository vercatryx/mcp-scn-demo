# Required — long random secret; clients send Authorization: Bearer <key>
DATA_COPILOT_MCP_API_KEY=

# Postgres (read-only user recommended)
DATABASE_URL=
# Or: INTERNAL_REPORTS_POSTGRES_URL=

# Optional — Supabase project ref for pooler host discovery
SUPABASE_URL=
# Or: NEXT_PUBLIC_SUPABASE_URL=

# Schema docs for the model (defaults to ../demo-food/docs/DATABASE_DATA_DICTIONARY.md)
# DATA_DICTIONARY_PATH=

# Excel exports (strongly recommended on Railway — ephemeral disk is not reliable)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_DOMAIN=

# Server
PORT=8080
HOST=0.0.0.0
# Comma-separated Host header allowlist (include your Railway domain)
# MCP_ALLOWED_HOSTS=your-service.up.railway.app,localhost
